{
  "grammars": [
    {
      "name": "folio",
      "camelcase": "Folio",
      "scope": "source.folio",
      "path": ".",
      "file-types": ["folio"],
      "injection-regex": "^folio$",
      "injections": ["queries/injections.scm"],
      "highlights": ["queries/highlights.scm"]
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "MIT",
    "description": "folio grammar for tree-sitter (dialogue/scripting layer over lish)"
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": true,
    "python": false,
    "rust": false,
    "swift": false,
    "kotlin": false
  }
}
